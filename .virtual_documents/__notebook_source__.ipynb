def _expand(s):
    if pd.isna(s) or not str(s).strip(): return []
    s = str(s).replace(" - ", ", ")
    return [g.strip() for g in s.split(",") if g.strip()]

loci["genes_list"] = loci["MAPPED_GENE"].apply(_expand)
