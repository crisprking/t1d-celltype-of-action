print("=" * 70)

sig_both = both[sig_t1d & sig_aab].sort_values("t1d_lmm_beta", ascending=False)
if len(sig_both):
    print("\nGenes with FDR < 0.10 in BOTH AAB and T1D (consistent across stages):")
    for _, r in sig_both.iterrows():
