            print(f"\n  --- {c} for T1D donors ---")
            print(t1d_subset.groupby("donor_id")[c].first().to_string())
    else:
        print("  No obvious duration/onset columns in obs.")

# --- 5. Always print: T1D donor list with cell counts for manual lookup --
