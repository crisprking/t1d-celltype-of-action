print(f"  Unique studies:            {t1d['STUDY ACCESSION'].nunique():,}")
print(f"  Unique SNPs (raw lead):    {t1d['SNPS'].nunique():,}")
print(f"  Genome-wide sig (p≤5e-8):  {len(gw):,}")
